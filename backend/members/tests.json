{
  "tests": [
    {
      "name": "GET members list",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200,
      "expectedBody": {"members": [], "total": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST create member",
      "method": "POST",
      "path": "/",
      "body": {
        "full_name": "Тестовый Участник Иванович",
        "rank": "Сержант",
        "years_from": 1975,
        "years_to": 1977,
        "battalion": "2-й учебный",
        "role": "Механик-водитель",
        "tanks": ["Т-55"],
        "hometown": "Москва"
      },
      "expectedStatus": 201,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST missing full_name returns 400",
      "method": "POST",
      "path": "/",
      "body": {"rank": "Рядовой"},
      "expectedStatus": 400
    },
    {
      "name": "GET admin without password returns 403",
      "method": "GET",
      "path": "/?admin=1",
      "expectedStatus": 403
    },
    {
      "name": "PATCH without password returns 403",
      "method": "PATCH",
      "path": "/",
      "body": {"id": 1, "action": "approve"},
      "expectedStatus": 403
    }
  ]
}